.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

.idea/*

#   API keys
*key*.yaml

#   Compressed folders
*.tar.gz

#   Hidden files
./.*

secret.yml
secret.yaml
# Dotfile secret manifests (e.g. applications/<app>/.secret.yaml) — never commit
.secret.yml
.secret.yaml
*.secret.yaml
*.secret.yml
# Filled-in Longhorn backup credentials (the .example.yaml template is committed)
longhorn-backup-secret.yaml
# Filled-in Grafana admin credentials (the .example.yaml template is committed)
grafana-admin-credentials.yaml
# Filled-in Grafana Auth0 credentials (the .example.yaml template is committed)
grafana-auth0.yaml
# Filled-in oauth2-proxy credentials (the .example.yaml template is committed)
/applications/oauth2-proxy/oauth2-proxy.yaml
/applications/oauth2-proxy/.oauth2-proxy.secret.yaml
result
result.json

# Terraform files
.terraform/
!.terraform.lock.hcl
*.tfstate
*.tfstate.backup
# Terraform secrets — never commit backend creds, var files, or keys
*.tfbackend
*.tfvars
*.pem

!clusters/*/rendered/*/result.json
